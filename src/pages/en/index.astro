---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';

import { companyName } from '~/i18n/ui';

const metadata = {
  title: 'Sudin',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero image={{ src: '~/assets/images/hero-image.jpg', alt: 'Sudin Hero Image' }}>
    <Fragment slot="title">
      Building together for <span class="text-accent dark:text-accent highlight">South Sudan</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">{companyName.en}</span>
    </Fragment>
  </Hero>
</Layout>
